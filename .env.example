# =============================================
# Dessa.id — Environment Variables
# Salin file ini ke .env.local untuk development
# =============================================

# JWT Secret (bisa diganti string acak apa saja untuk local)
JWT_SECRET=dessa-super-secret-key-for-local-dev-only

# =============================================
# MIDTRANS — Payment Gateway
# Daftar akun sandbox di: https://dashboard.sandbox.midtrans.com
# =============================================
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Ganti ke "production" saat go-live
MIDTRANS_MODE=sandbox
